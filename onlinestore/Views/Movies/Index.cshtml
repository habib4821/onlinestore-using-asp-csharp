@model IEnumerable<Movie>

@{
    ViewData["Title"] = "List of Movies";
}

<div class="container">
    <div class="row g-4">

        @foreach (var item in Model)
        {
            <div class="col-12 col-md-4">

                <div class="card h-100">

                    <!-- HEADER -->
                    <div class="card-header text-white bg-info">
                        <h5 class="card-title d-flex justify-content-between align-items-center mb-0">
                            @item.Name

                            <a class="text-white">
                                <i class="bi bi-pencil-square"></i>
                            </a>
                        </h5>
                    </div>

                    <!-- BODY -->
                    <div class="row g-0">

                        <div class="col-5">
                            <img src="@item.ImageURL"
                                 class="img-fluid h-100 w-100"
                                 style="object-fit: cover;"
                                 alt="@item.Name" />
                        </div>

                        <div class="col-7">
                            <div class="card-body">

                                <p class="card-text">@item.Desc</p>

                                <p class="card-text">
                                    <b>Cinema:</b> @item.Cinema?.Name
                                </p>

                                <p class="card-text">
                                    <b>Category:</b> @item.MovieCategory
                                </p>

                                <p class="card-text">
                                    <b>Start:</b> @item.StartDate.ToString("dd MMM yy")
                                </p>

                                <p class="card-text">
                                    <b>End:</b> @item.EndDate.ToString("dd MMM yy")
                                </p>

                                <p class="card-text">
                                    <b>Status:</b>

                                    @if (DateTime.Now >= item.StartDate && DateTime.Now <= item.EndDate)
                                    {
                                        <span class="badge bg-success">AVAILABLE</span>
                                    }
                                    else if (DateTime.Now > item.EndDate)
                                    {
                                        <span class="badge bg-danger">EXPIRED</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary">UPCOMING</span>
                                    }
                                </p>

                            </div>
                        </div>

                    </div>

                    <!-- FOOTER -->
                    <div class="card-footer">
                        <div class="d-flex justify-content-between">

                            <a class="btn btn-outline-primary">
                                <i class="bi bi-eye-fill"></i> Show Details
                            </a>

                            <a class="btn btn-success text-white">
                                <i class="bi bi-cart-plus"></i>
                                Add to Cart (@item.Price.ToString("c"))
                            </a>

                        </div>
                    </div>

                </div>

            </div>
        }

    </div>
</div>