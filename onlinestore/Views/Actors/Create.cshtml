@model Actor

@{
    ViewData["Title"] = "Add a New Actor";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="mb-3">
                <h1 class="fw-bold">Add New Actor</h1>
            </div>
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                        <div class="mb-4">
                            <label asp-for="ProfilePictureURL" class="form-label fw-semibold"></label>
                            <input asp-for="ProfilePictureURL" class="form-control" placeholder="Paste image URL here" />
                            <span asp-validation-for="ProfilePictureURL" class="text-danger"></span>
                            <div class="mt-4 text-center">
                                <p class="fw-semibold mb-2">Profile Picture Preview</p>
                                <img id="ProfilePictureUrlPreview" class="img-fluid rounded-4 shadow-sm border" style="max-height: 320px; width: 100%;object-fit: cover; display: none;" />
                            </div>
                        </div>
                        <div class="mb-4">
                            <label asp-for="FullName" class="form-label fw-semibold"></label>
                            <input asp-for="FullName" class="form-control" placeholder="Enter actor full name" />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>
                        <div class="mb-4">
                            <label asp-for="Bio" class="form-label fw-semibold"></label>
                            <textarea asp-for="Bio" class="form-control" rows="5" placeholder="Write actor biography"></textarea>
                                <span asp-validation-for="Bio" class="text-danger"></span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary">Show All</a>
                                <button type="submit" class="btn btn-success px-4">Create</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
     }
    <script>
            $("#ProfilePictureURL").on("input", function () {
            var imageUrl = $(this).val() || " ";
                var output = document.getElementById("ProfilePictureUrlPreview");
                console.log(imageUrl);
            if (imageUrl.trim() !== "" ) {
                output.src = imageUrl;
                output.style.display = "block";
                }else{
                    output.style.display = "none";
                }
        });
    </script>
}