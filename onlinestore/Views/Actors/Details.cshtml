@model Actor

@{
    ViewData["Title"] = "Actor Details";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="row g-0">

                    <!-- Left Side Image -->
                    <div class="col-md-5">
                        <div class="h-100">
                            <img id="ProfilePicturePreview"
                                 src="@Model.ProfilePictureURL"
                                 alt="@Model.FullName"
                                 class="img-fluid w-100 h-100 object-fit-cover" />
                        </div>
                    </div>

                    <!-- Right Side Content -->
                    <div class="col-md-7">
                        <div class="card-body p-5">

                            <div class="mb-4">
                                <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill">
                                    Actor Profile
                                </span>
                            </div>

                            <h1 class="fw-bold mb-3 display-6">
                                @Model.FullName
                            </h1>

                            <hr class="mb-4" />

                            <div class="mb-4">
                                <h5 class="fw-semibold text-muted mb-3">
                                    Biography
                                </h5>

                                <p class="text-secondary lh-lg">
                                    @Model.Bio
                                </p>
                            </div>

                            <div class="d-flex gap-3 mt-5">

                                <a asp-action="Edit"
                                   asp-route-id="@Model.Id"
                                   class="btn btn-success px-4 py-2 rounded-pill shadow-sm">
                                    <i class="bi bi-pencil-square me-2"></i>
                                    Edit Profile
                                </a>

                                <a asp-action="Index"
                                   class="btn btn-outline-dark px-4 py-2 rounded-pill">
                                    <i class="bi bi-arrow-left me-2"></i>
                                    Back to List
                                </a>

                            </div>

                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
